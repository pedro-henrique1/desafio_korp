{
  "title": "Projeto Korp - http-server-projeto-korp",
  "uid": "projeto-korp-dashboard",
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "5s",
  "time": { "from": "now-15m", "to": "now" },
  "panels": [
    {
      "id": 2,
      "title": "Volume de requisições (taxa por segundo)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total[1m])) by (path, status)",
          "legendFormat": "{{path}} - {{status}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 1,
      "title": "Disponibilidade do serviço",
      "type": "stat",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [
        {
          "expr": "up{job=\"http-server-projeto-korp\"}",
          "legendFormat": "up",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "Indisponível", "color": "red" } } },
            { "type": "value", "options": { "1": { "text": "Disponível", "color": "green" } } }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
       "graphMode": "none",
       "textMode": "value",
       "justifyMode": "center"
      }
    },
    {
      "id": 3,
      "title": "Total de requisições acumuladas",
      "type": "stat",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [
        {
          "expr": "sum(http_requests_total)",
          "legendFormat": "total",
          "refId": "A"
        }
      ]
    }
  ]
}